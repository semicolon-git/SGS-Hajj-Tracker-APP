{
  "expo": {
    "name": "SGS BagScan",
    "slug": "mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sgsbagscan",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/2ad9528a-9c02-4ed0-99dd-340a755d25d5"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.semicolon.sa.sgsbagscan",
      "infoPlist": {
        "NSCameraUsageDescription": "SGS BagScan uses the camera to scan luggage tag barcodes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.semicolon.sgsbagscan",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "SGS BagScan uses Face ID to quickly unlock your shift."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SGS BagScan uses the camera to scan luggage tag barcodes."
        }
      ],
      "./plugins/withZebraScan.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "env": {
          "EXPO_PUBLIC_SGS_API_URL": "https://api-bagtracker-prod.saudiags.com"
        },
        "projectId": "2ad9528a-9c02-4ed0-99dd-340a755d25d5"
      }
    },
    "owner": "loqman"
  }
}
